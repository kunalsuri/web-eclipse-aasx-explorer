# DevNest Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Database Configuration
# Replace with your actual PostgreSQL database URL
DATABASE_URL="postgresql://username:password@localhost:5432/devnest_db"

# Session Security
# Generate a secure random string for production
SESSION_SECRET="your-secure-session-secret-key-here"

# Server Configuration
# Port for the development server (default: 5000)
PORT=5000

# Environment
NODE_ENV=development

# Optional: Replit Configuration (if deploying on Replit)
# REPL_ID=your-repl-id-here

# Dictionary Integration Configuration
# ECLASS API Configuration
ECLASS_API_URL=https://eclass-cdp.com/xmlapi/v1
ECLASS_API_KEY=your-eclass-api-key-here
ECLASS_API_TIMEOUT=30000

# IEC CDD API Configuration
IECCDD_API_URL=https://cdd.iec.ch/api/v1
IECCDD_API_KEY=your-ieccdd-api-key-here
IECCDD_API_TIMEOUT=30000

# Dictionary Cache Configuration
DICTIONARY_CACHE_TTL=86400
DICTIONARY_CACHE_MAX_SIZE=1000
